# MongoDB
# Docker: use service name "mongo". Local (no Docker): use localhost:27017
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=document_insights

# Redis
# Docker: use service name "redis". Local (no Docker): use localhost:6379
REDIS_URL=redis://redis:6379/0

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
